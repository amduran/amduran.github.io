---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getUi, collectionData } from '../../lib/content';
import { route } from '../../lib/routes';
import { t, authorsHtml, extractQuartile, quartileBadgeClass, resourceLinks } from '../../lib/utils';

export async function getStaticPaths() {
  const papers = await collectionData('papers');
  return papers.map((row) => ({ params: { id: String(row.idx) }, props: { row } }));
}

const lang = 'es';
const { row } = Astro.props;
const ui = await getUi(lang);
const q = extractQuartile(row.impact);
const links = resourceLinks(row, ui, true);
---
<BaseLayout lang={lang} routeKey="publication" routeId={row.idx} title={row.title}>
  <div class="container detail-shell">
    <article class="card-surface detail-card">
      <div class="detail-header-row"><p class="meta-label">{t(ui, 'journal_article')}</p>{q !== 'none' ? <span class:list={["quartile-badge", quartileBadgeClass(q)]}>{q}</span> : <span class="quartile-badge is-none">{t(ui, 'without_quartile')}</span>}</div>
      <h1 class="page-title detail-title">{row.title}</h1>
      <div class="detail-meta-grid">
        <p><span>{t(ui, 'authors')}</span><span set:html={authorsHtml(row.authors)}></span></p>
        <p><span>{t(ui, 'journal')}</span>{row.journal}</p>
        <p><span>{t(ui, 'volume')}</span>{row.volume}</p>
        <p><span>{t(ui, 'impact')}</span>{row.impact}</p>
        <p><span>{t(ui, 'year')}</span>{row.year}</p>
        <p><span>{t(ui, 'pages')}</span>{row.pages}</p>
      </div>
      <div class="resource-pill-row">{links.map((link) => <a class:list={["resource-pill", link.className]} href={link.href} target={link.external ? '_blank' : undefined} rel={link.external ? 'noopener noreferrer' : undefined}>{link.label}</a>)}</div>
      {row.abstract && <section class="detail-section"><h2>{t(ui, 'abstract')}</h2><p set:html={row.abstract}></p></section>}
      {row.citation && <section class="detail-section" id="citation-block"><h2>{t(ui, 'citation')}</h2><pre class="citation-block"><code>{row.citation}</code></pre></section>}
    </article>
    <p class="detail-back"><a class="text-link" href={route(lang, 'publications')}>← {t(ui, 'publications')}</a></p>
  </div>
</BaseLayout>
