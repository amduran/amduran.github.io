---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/PageIntro.astro';
import { getSite, getUi } from '../../lib/content';
import { t } from '../../lib/utils';

const lang = 'es';
const site = await getSite();
const ui = await getUi(lang);
const subject = 'Contacto académico';
const mailHref = `mailto:${site.email}?subject=${encodeURIComponent(subject)}`;
---
<BaseLayout lang={lang} routeKey="contact" title={t(ui, 'contact_page_title')}>
  <PageIntro eyebrow={t(ui, 'contact')} title={t(ui, 'contact_page_title')} description={t(ui, 'contact_page_desc')} />

  <section class="container contact-grid content-block">
    <div class="card-surface contact-panel">
      <h2>{t(ui, 'contact_details')}</h2>
      <div class="contact-list contact-large">
        <p><i class="fas fa-envelope"></i> <a href={`mailto:${site.email}`}>{site.email}</a></p>
        <p><i class="fas fa-location-dot"></i> {site.location}</p>
        <p><i class="fas fa-phone"></i> {site.phone}</p>
      </div>
      <div class="map-frame">
        <iframe
          class="map"
          title="Mapa de ubicación de Universidad Loyola Andalucía"
          src="https://www.openstreetmap.org/export/embed.html?bbox=-4.8070%2C37.8590%2C-4.7740%2C37.8770&layer=mapnik"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
        <button class="map-marker" type="button" aria-label="Universidad Loyola Andalucía" title="Universidad Loyola Andalucía">
          <span class="map-tooltip">Universidad Loyola Andalucía</span>
        </button>
      </div>
    </div>

    <div class="card-surface contact-panel">
      <h2>{t(ui, 'send_message')}</h2>
      <p>
        Para contactar conmigo, puedes escribirme directamente por correo electrónico.
      </p>
      <p>
        <a class="button-primary" href={mailHref}>{t(ui, 'send')}</a>
      </p>
    </div>
  </section>
</BaseLayout>
